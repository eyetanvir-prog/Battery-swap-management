@model BatterySwap.MVC.Models.RechargeClientViewModel
@{
    ViewData["Title"] = "Recharge Client";
}

<div class="app-content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="mb-0">Recharge Client</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-end">
                    <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Home</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Client" asp-action="Index">Clients</a></li>
                    <li class="breadcrumb-item active">Recharge</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="app-content">
    <div class="container-fluid">
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="card card-outline card-warning">
                    <div class="card-header">
                        <h3 class="card-title">Wallet Recharge</h3>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                        {
                            <div class="alert alert-danger py-2">@Model.ErrorMessage</div>
                        }

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <div class="small text-muted">Client</div>
                                <div class="fw-semibold">@Model.ClientName</div>
                            </div>
                            <div class="col-md-3">
                                <div class="small text-muted">Phone</div>
                                <div class="fw-semibold">@Model.Phone</div>
                            </div>
                            <div class="col-md-3">
                                <div class="small text-muted">Current Balance</div>
                                <div class="fw-semibold">@Model.CurrentBalance</div>
                            </div>
                        </div>

                        <form asp-action="Recharge" method="post">
                            <input asp-for="ClientId" type="hidden" />
                            <input asp-for="ClientName" type="hidden" />
                            <input asp-for="Phone" type="hidden" />
                            <input asp-for="CurrentBalance" type="hidden" />
                            <input asp-for="RequiresStationSelection" type="hidden" />

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="Amount" class="form-label"></label>
                                    <input asp-for="Amount" class="form-control" />
                                    <span asp-validation-for="Amount" class="text-danger"></span>
                                </div>
                                @if (Model.RequiresStationSelection)
                                {
                                    <div class="col-md-6">
                                        <label asp-for="StationId" class="form-label"></label>
                                        <select asp-for="StationId" class="form-select">
                                            <option value="">Select a station</option>
                                            @foreach (var station in Model.Stations)
                                            {
                                                <option value="@station.Id">@station.Label</option>
                                            }
                                        </select>
                                        <span asp-validation-for="StationId" class="text-danger"></span>
                                    </div>
                                }
                                else
                                {
                                    <div class="col-md-6">
                                        <label class="form-label">Station</label>
                                        <div class="form-control bg-body-tertiary">Your assigned station will be used automatically.</div>
                                    </div>
                                }
                            </div>

                            <div class="mt-4 d-flex gap-2">
                                <button type="submit" class="btn btn-warning">Add Balance</button>
                                <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
