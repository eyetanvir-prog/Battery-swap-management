@model BatterySwap.MVC.Models.RechargeHistoryListViewModel
@{
    ViewData["Title"] = "Recharge History";
    var totalRecharges = Model.Items.Count;
    var totalAmount = Model.Items.Sum(x =>
    {
        var raw = x.Amount.Replace(" Tk", string.Empty, StringComparison.OrdinalIgnoreCase);
        return decimal.TryParse(raw, out var value) ? value : 0m;
    });
    var distinctClients = Model.Items.Select(x => x.ClientPhone).Distinct(StringComparer.OrdinalIgnoreCase).Count();
}

<div class="app-content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="mb-0">Recharge History</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-end">
                    <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Home</a></li>
                    <li class="breadcrumb-item active">Recharge History</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="app-content">
    <div class="container-fluid">
        <div class="row g-3 mb-3">
            <div class="col-md-4">
                <div class="small-box text-bg-warning">
                    <div class="inner">
                        <h3>@totalRecharges</h3>
                        <p>Total Recharges</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="small-box text-bg-dark">
                    <div class="inner">
                        <h3>@totalAmount.ToString("0.##")</h3>
                        <p>Recharge Amount (Tk)</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="small-box text-bg-secondary">
                    <div class="inner">
                        <h3>@distinctClients</h3>
                        <p>Clients Recharged</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="card card-outline card-warning">
            <div class="card-header">
                <h3 class="card-title">Balance Recharge Transactions</h3>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table id="rechargeHistoryTable" class="table table-hover table-sm align-middle w-100 js-datatable" data-page-length="10" data-export-title="Recharge History">
                        <thead>
                            <tr>
                                <th>Client</th>
                                <th>Phone</th>
                                <th>Station</th>
                                <th>Amount</th>
                                <th>Time</th>
                                <th>Added By</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td class="fw-semibold">
                                        <a asp-controller="Client" asp-action="Profile" asp-route-id="@item.ClientId" class="text-reset text-decoration-none">
                                            @item.ClientName
                                        </a>
                                    </td>
                                    <td>@item.ClientPhone</td>
                                    <td>@item.StationName</td>
                                    <td>@item.Amount</td>
                                    <td>@item.RechargeTime</td>
                                    <td>@item.AddedBy</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
