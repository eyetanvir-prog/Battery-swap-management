@model BatterySwap.MVC.Models.ErrorViewModel
@{
    ViewData["Title"] = Model.PageTitle;
}

<div class="app-content error-page-wrap">
    <div class="container-fluid">
        <div class="row justify-content-center py-5">
            <div class="col-lg-7 col-xl-6">
                <div class="card card-outline card-danger shadow-sm">
                    <div class="card-body text-center p-4 p-lg-5">
                        <div class="error-code-display">@(Model.StatusCode?.ToString() ?? "Oops")</div>
                        <h1 class="error-page-title">@Model.Headline</h1>
                        <p class="text-muted mb-4">@Model.Description</p>

                        <div class="d-flex justify-content-center gap-2 flex-wrap">
                            @if (!string.IsNullOrWhiteSpace(Model.ActionUrl) && !string.IsNullOrWhiteSpace(Model.ActionLabel))
                            {
                                <a href="@Model.ActionUrl" class="btn btn-primary">@Model.ActionLabel</a>
                            }
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary">Sign In Again</a>
                        </div>

                        @if (Model.ShowRequestId)
                        {
                            <div class="alert alert-light border mt-4 mb-0 text-start small">
                                <div><strong>Request ID:</strong> <code>@Model.RequestId</code></div>
                                @if (Model.StatusCode.HasValue)
                                {
                                    <div class="mt-1"><strong>Status Code:</strong> <code>@Model.StatusCode</code></div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
