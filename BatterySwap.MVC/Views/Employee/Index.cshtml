@model BatterySwap.MVC.Models.EmployeeListViewModel
@{
    ViewData["Title"] = "Employees";
}

<div class="app-content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="mb-0">Employees</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-end">
                    <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Home</a></li>
                    <li class="breadcrumb-item active">Employees</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="app-content">
    <div class="container-fluid">
        <div class="card card-outline card-primary">
            <div class="card-header">
                <h3 class="card-title">Station Employee Directory</h3>
                <div class="card-tools">
                    <a asp-action="Create" class="btn btn-primary btn-xs">Add Employee</a>
                </div>
            </div>
            <div class="card-body">
                @if (TempData["SuccessMessage"] is string successMessage)
                {
                    <div class="alert alert-success py-2">@successMessage</div>
                }
                @if (TempData["ErrorMessage"] is string errorMessage)
                {
                    <div class="alert alert-danger py-2">@errorMessage</div>
                }
                <div class="table-responsive">
                    <table id="employeeTable" class="table table-hover table-sm align-middle w-100 js-datatable" data-page-length="10" data-export-title="Employees">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Username</th>
                                <th>Phone</th>
                                <th>NID</th>
                                <th>Station</th>
                                <th>Status</th>
                                <th>Joining Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var employee in Model.Employees)
                            {
                                <tr>
                                    <td class="fw-semibold">@employee.Name</td>
                                    <td>@employee.Username</td>
                                    <td>@employee.Phone</td>
                                    <td>@employee.NID</td>
                                    <td>@employee.StationName</td>
                                    <td>
                                        <span class="badge @(employee.Status == "Active" ? "text-bg-success" : "text-bg-secondary")">
                                            @employee.Status
                                        </span>
                                    </td>
                                    <td>@employee.JoiningDate</td>
                                    <td>
                                        <div class="d-flex gap-1">
                                            <a asp-action="Edit" asp-route-id="@employee.Id" class="btn btn-outline-primary btn-xs">Edit</a>
                                            @if (employee.Status == "Active")
                                            {
                                                <form asp-action="Deactivate" asp-route-id="@employee.Id" method="post" onsubmit="return confirm('Deactivate this employee?');">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-outline-danger btn-xs">Deactivate</button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
