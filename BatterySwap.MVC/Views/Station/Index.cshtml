@using Microsoft.AspNetCore.Http
@model BatterySwap.MVC.Models.StationListViewModel
@{
    ViewData["Title"] = "Stations";
    var isAdmin = string.Equals(Context.Session.GetString("UserRole"), "Admin", StringComparison.OrdinalIgnoreCase);
}

<div class="app-content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="mb-0">Stations</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-end">
                    <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Home</a></li>
                    <li class="breadcrumb-item active">Stations</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="app-content">
    <div class="container-fluid">
        <div class="card card-outline card-info">
            <div class="card-header">
                <h3 class="card-title">Station Overview</h3>
                @if (isAdmin)
                {
                    <div class="card-tools">
                        <a asp-action="Create" class="btn btn-info btn-xs">Add Station</a>
                    </div>
                }
            </div>
            <div class="card-body">
                @if (TempData["SuccessMessage"] is string successMessage)
                {
                    <div class="alert alert-success py-2">@successMessage</div>
                }
                @if (TempData["ErrorMessage"] is string errorMessage)
                {
                    <div class="alert alert-danger py-2">@errorMessage</div>
                }
                <div class="table-responsive">
                    <table id="stationTable" class="table table-hover table-sm align-middle w-100 js-datatable" data-page-length="10" data-export-title="Stations">
                        <thead>
                            <tr>
                                <th>Station</th>
                                <th>Code</th>
                                <th>Address</th>
                                <th>Available</th>
                                <th>Total</th>
                                <th>Employee</th>
                                <th>Status</th>
                                @if (isAdmin)
                                {
                                    <th>Actions</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var station in Model.Stations)
                            {
                                <tr>
                                    <td class="fw-semibold">@station.StationName</td>
                                    <td>@station.StationCode</td>
                                    <td>@station.Address</td>
                                    <td>@station.AvailableBatteries</td>
                                    <td>@station.TotalBatteries</td>
                                    <td>@station.EmployeeName</td>
                                    <td>
                                        <span class="badge @(station.Status == "Open" ? "text-bg-success" : "text-bg-secondary")">@station.Status</span>
                                    </td>
                                    @if (isAdmin)
                                    {
                                        <td>
                                            <a asp-action="Edit" asp-route-id="@station.Id" class="btn btn-outline-info btn-xs">Edit</a>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
