@model BatterySwap.MVC.Models.DashboardViewModel
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Dashboard";
    var userRole = Context.Session.GetString("UserRole") ?? "Admin";
    var chartLabels = System.Text.Json.JsonSerializer.Serialize(Model.StationStocks.Select(x => x.StationCode));
    var chartAvailable = System.Text.Json.JsonSerializer.Serialize(Model.StationStocks.Select(x => x.AvailableBatteries));
    var chartInUse = System.Text.Json.JsonSerializer.Serialize(Model.StationStocks.Select(x => x.TotalBatteries - x.AvailableBatteries));
}

<div class="app-content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="mb-0">Operations Dashboard</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-end">
                    <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Home</a></li>
                    <li class="breadcrumb-item active">Dashboard</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="app-content">
    <div class="container-fluid">
        <div class="row">
            @foreach (var stat in Model.StatCards)
            {
                <div class="col-lg-3 col-6">
                    <div class="small-box compact-box @stat.AccentClass">
                        <div class="inner">
                            <h3>@stat.Value</h3>
                            <p>@stat.Title</p>
                            <small>@stat.Subtitle</small>
                        </div>
                        <i class="small-box-icon @stat.IconClass"></i>
                    </div>
                </div>
            }
        </div>

        <div class="row">
            @foreach (var stat in Model.Highlights)
            {
                <div class="col-lg-3 col-sm-6">
                    <div class="info-box shadow-sm dashboard-highlight">
                        <span class="info-box-icon @stat.AccentClass">
                            <i class="@stat.IconClass"></i>
                        </span>
                        <div class="info-box-content">
                            <span class="info-box-text">@stat.Title</span>
                            <span class="info-box-number">@stat.Value</span>
                            <span class="dashboard-highlight-note">@stat.Subtitle</span>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="row">
            <section class="col-lg-7">
                <div class="card card-outline card-primary">
                    <div class="card-header">
                        <h3 class="card-title">Recent Activity</h3>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            @foreach (var activity in Model.RecentActivities)
                            {
                                <div class="list-group-item px-3 py-3">
                                    <div class="d-flex justify-content-between align-items-start gap-3">
                                        <div>
                                            <div class="fw-semibold">@activity.Title</div>
                                            <div class="text-muted small mt-1">@activity.Detail</div>
                                        </div>
                                        <div class="text-end">
                                            <span class="badge @activity.BadgeClass">@activity.BadgeText</span>
                                            <div class="small text-muted mt-2">@activity.RelativeTime</div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </section>

            <section class="col-lg-5">
                <div class="card card-outline card-success">
                    <div class="card-header">
                        <h3 class="card-title">Quick Actions</h3>
                    </div>
                    <div class="card-body">
                        <div class="dashboard-actions">
                            @if (string.Equals(userRole, "Admin", StringComparison.OrdinalIgnoreCase))
                            {
                                <a asp-controller="Client" asp-action="Create" class="btn btn-success btn-sm"><i class="bi bi-person-plus me-1"></i>Register Client</a>
                                <a asp-controller="Employee" asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-person-workspace me-1"></i>Add Employee</a>
                                <a asp-controller="Station" asp-action="Create" class="btn btn-info btn-sm"><i class="bi bi-geo-alt me-1"></i>Add Station</a>
                                <a asp-controller="Battery" asp-action="Create" class="btn btn-secondary btn-sm"><i class="bi bi-battery-charging me-1"></i>Add Battery</a>
                            }
                            else
                            {
                                <a asp-controller="Swap" asp-action="Process" class="btn btn-danger btn-sm"><i class="bi bi-arrow-repeat me-1"></i>Open Swap Desk</a>
                                <a asp-controller="Client" asp-action="Create" class="btn btn-success btn-sm"><i class="bi bi-person-plus me-1"></i>Register Client</a>
                                <a asp-controller="Client" asp-action="Index" class="btn btn-warning btn-sm"><i class="bi bi-wallet2 me-1"></i>Recharge Wallet</a>
                                <a asp-controller="History" asp-action="Swaps" class="btn btn-outline-dark btn-sm"><i class="bi bi-clock-history me-1"></i>View Swap Log</a>
                            }
                        </div>
                        <hr />
                        <div class="dashboard-note-list">
                            <div><i class="bi bi-check2-circle text-success me-2"></i>Live data from the API and SQL Server</div>
                            <div><i class="bi bi-check2-circle text-success me-2"></i>Compact DataTables throughout the system</div>
                            <div><i class="bi bi-check2-circle text-success me-2"></i>Swagger available directly from the sidebar</div>
                            <div><i class="bi bi-check2-circle text-success me-2"></i>Role-aware operations for Admin and Employee users</div>
                        </div>
                    </div>
                </div>
            </section>
        </div>

        <div class="row">
            <section class="col-xl-7">
                <div class="card card-outline card-info">
                    <div class="card-header">
                        <h3 class="card-title">Station Battery Stock</h3>
                    </div>
                    <div class="card-body table-responsive py-2">
                        <table id="stationStockTable" class="table table-hover table-sm align-middle w-100 js-datatable" data-page-length="5" data-export-title="Station Stock">
                            <thead>
                                <tr>
                                    <th>Station</th>
                                    <th>Code</th>
                                    <th>Available</th>
                                    <th>Total</th>
                                    <th>Assigned Employee</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var station in Model.StationStocks)
                                {
                                    <tr>
                                        <td>@station.StationName</td>
                                        <td>@station.StationCode</td>
                                        <td>@station.AvailableBatteries</td>
                                        <td>@station.TotalBatteries</td>
                                        <td>@station.EmployeeName</td>
                                        <td>
                                            <span class="badge text-bg-success">@station.Status</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
            <section class="col-xl-5">
                <div class="card card-outline card-dark">
                    <div class="card-header">
                        <h3 class="card-title">Battery Availability Chart</h3>
                    </div>
                    <div class="card-body">
                        <div class="dashboard-chart-wrap">
                            <canvas id="stationBatteryChart"></canvas>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js" crossorigin="anonymous"></script>
    <script>
        (() => {
            const canvas = document.getElementById("stationBatteryChart");
            if (!canvas || typeof Chart === "undefined") {
                return;
            }

            const labels = @Html.Raw(chartLabels);
            const available = @Html.Raw(chartAvailable);
            const inUse = @Html.Raw(chartInUse);

            new Chart(canvas, {
                type: "bar",
                data: {
                    labels,
                    datasets: [
                        {
                            label: "Available",
                            data: available,
                            backgroundColor: "#198754",
                            borderRadius: 6
                        },
                        {
                            label: "With Client",
                            data: inUse,
                            backgroundColor: "#dc3545",
                            borderRadius: 6
                        }
                    ]
                },
                options: {
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: "bottom"
                        }
                    },
                    scales: {
                        x: {
                            stacked: false,
                            ticks: {
                                font: {
                                    size: 11
                                }
                            }
                        },
                        y: {
                            beginAtZero: true,
                            ticks: {
                                precision: 0
                            }
                        }
                    }
                }
            });
        })();
    </script>
}
